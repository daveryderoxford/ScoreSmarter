{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2022",
    "types": [
      "node"
    ],
    "paths": {
      "@shared/scanner-context": [
        "../../shared/contracts/scanner-context.d.ts"
      ]
    },
    "rootDir": "src",
    "skipLibCheck": true
  },
  "compileOnSave": true,
  "exclude": [
    "node_modules"
  ]
}
